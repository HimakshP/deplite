{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": false,
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["src", "src/deplite.ts"]
}